# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.

# Required for the "Retention Actions" page in the Streamlit app.
# Free tier available — get your key at: https://console.groq.com/
GROQ_API_KEY=gsk_your-key-here

# Optional — enables persistent conversation history, audit trail, and feedback loop.
# Free PostgreSQL at: https://supabase.com (500MB free tier)
# Copy from: Supabase project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
