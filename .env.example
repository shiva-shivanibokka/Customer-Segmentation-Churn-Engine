# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.
# This single file is used by BOTH the Python pipeline and the Next.js dashboard.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Free tier at https://supabase.com
# All three values are in: Supabase project → Settings → API

# REST API URL (used by the Next.js dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Service role key — server-side only, bypasses RLS for writes
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Direct PostgreSQL connection string (used by the Python pipeline)
# Supabase project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ── Groq (LLM) ────────────────────────────────────────────────────────────────
# Free tier at https://console.groq.com
GROQ_API_KEY=gsk_your-key-here

# ── Kaggle (dataset download) ─────────────────────────────────────────────────
# Only needed to download raw datasets via the pipeline
KAGGLE_USERNAME=your-username
KAGGLE_KEY=your-kaggle-api-key
